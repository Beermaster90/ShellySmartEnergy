{
  "destination": "Shelly Cloud",
  "operation": "Get relay device status",
  "request": {
    "method": "GET",
    "url": "https://shelly-api.example.com/device/status",
    "query": {
      "id": "shelly-device-id",
      "auth_key": "replace-with-shelly-auth-key"
    },
    "timeout_seconds": 15
  },
  "response": {
    "isok": true,
    "data": {
      "id": "cloud-device-id",
      "online": true,
      "device_status": {
        "switch:0": {
          "id": 0,
          "output": true,
          "source": "HTTP_in"
        }
      }
    }
  }
}
